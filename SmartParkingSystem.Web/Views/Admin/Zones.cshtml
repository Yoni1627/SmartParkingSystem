@model IEnumerable<SmartParkingSystem.Core.Entities.ParkingZone>

@{
    ViewData["Title"] = "Manage Zones";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Manage Parking Zones</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createZoneModal">
        <i class="fa-solid fa-plus me-2"></i>Add New Zone
    </button>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="glass-panel h-100 position-relative group">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h3 class="mb-1 text-primary">@item.Name</h3>
                        <p class="text-muted small mb-0">
                            <i class="fa-solid fa-location-dot me-1"></i> @item.Location
                        </p>
                    </div>
                    <div class="text-end">
                        <div class="fs-4 fw-bold">$@item.HourlyRate.ToString("0.00")</div>
                        <div class="text-muted small">per hour</div>
                    </div>
                </div>
                
                <div class="mt-4 d-flex justify-content-between align-items-center">
                    <a asp-action="Slots" asp-route-zoneId="@item.Id" class="btn btn-glass btn-sm">
                        <i class="fa-solid fa-eye me-1"></i> View Slots
                    </a>
                    
                    <form asp-action="DeleteZone" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button type="submit" class="btn btn-sm btn-danger opacity-50 hover-opacity-100 transition-all" onclick="return confirm('Are you sure you want to delete this zone?');">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="glass-panel text-center py-5 mt-4">
        <i class="fa-solid fa-folder-open fa-3x mb-3 text-muted opacity-30"></i>
        <h3 class="text-muted">No zones found.</h3>
        <p class="text-secondary">Add one to get started!</p>
    </div>
}

<!-- Create Zone Modal -->
<div class="modal fade" id="createZoneModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content glass-panel p-0 border-0">
            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title text-white">Add New Parking Zone</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="CreateZone" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Zone Name</label>
                        <input type="text" name="Name" class="form-control-glass" required placeholder="e.g. Ground Floor A" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Location Details</label>
                        <input type="text" name="Location" class="form-control-glass" placeholder="e.g. Near North Entrance" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hourly Rate ($)</label>
                        <input type="number" step="0.01" name="HourlyRate" class="form-control-glass" required value="2.50" />
                    </div>
                </div>
                <div class="modal-footer border-top border-secondary">
                    <button type="button" class="btn btn-glass" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Zone</button>
                </div>
            </form>
        </div>
    </div>
</div>
