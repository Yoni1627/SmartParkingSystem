@model SmartParkingSystem.Core.Entities.Reservation

@{
    ViewData["Title"] = "Booking Confirmed";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="glass-panel mt-5 text-center p-5">
            <div class="mb-4">
                <i class="fa-solid fa-circle-check fa-5x text-success"></i>
            </div>
            <h2 class="mb-3">Booking Confirmed!</h2>
            <p class="text-muted mb-4">Your parking slot has been successfully reserved and payment is complete.</p>
            
            <div class="row text-start mb-4 bg-dark bg-opacity-50 p-4 rounded border border-secondary">
                <div class="col-6 mb-3">
                    <div class="text-muted small text-uppercase">Reservation ID</div>
                    <div class="fw-bold fs-5">#@Model.Id.ToString("00000")</div>
                </div>
                <div class="col-6 mb-3 text-end">
                    <div class="text-muted small text-uppercase">Amount Paid</div>
                    <div class="fw-bold fs-5 text-primary">$@Model.TotalAmount.ToString("0.00")</div>
                </div>
                <div class="col-6 mb-3">
                    <div class="text-muted small text-uppercase">Zone</div>
                    <div class="fw-bold">@Model.ParkingSlot?.ParkingZone?.Name</div>
                </div>
                <div class="col-6 mb-3 text-end">
                    <div class="text-muted small text-uppercase">Slot</div>
                    <div class="badge badge-success fs-6">@Model.ParkingSlot?.Name</div>
                </div>
                <div class="col-12 mt-2 pt-3 border-top border-secondary text-center">
                    <div class="text-muted small text-uppercase mb-1">Time Window</div>
                    <div class="fw-bold">@Model.StartTime.ToLocalTime().ToString("MMM dd, h:mm tt") &mdash; @Model.EndTime.ToLocalTime().ToString("h:mm tt")</div>
                </div>
            </div>

            <!-- Simulated QR Code using an API for quick setup -->
            <div class="mb-4 p-4 bg-white rounded d-inline-block border border-4 border-primary">
                <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=PARKING-@Model.Id" alt="Entry QR Code" class="img-fluid" />
            </div>
            <p class="text-muted small mb-4"><i class="fa-solid fa-info-circle me-1"></i> Scan this QR code at the entrance gate.</p>

            <div>
                <button class="btn btn-primary me-2"><i class="fa-solid fa-download me-2"></i>Download Receipt</button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-glass">Return Home</a>
            </div>
        </div>
    </div>
</div>
